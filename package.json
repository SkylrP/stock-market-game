{
  "name": "stock-market-game",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "cd worker && npx wrangler dev",
    "build": "tsc && vite build",
    "build:worker": "cd worker && npx tsc --noEmit",
    "preview": "vite preview",
    "deploy": "npm run build && npx wrangler pages deploy dist",
    "deploy:worker": "cd worker && npx wrangler deploy"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^0.21.1",
    "@types/node": "^22.9.0",
    "wrangler": "^3.84.0",
    "@cloudflare/workers-types": "^4.20250401.0"
  }
}